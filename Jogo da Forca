#include <stdio.h>
#include <string.h>

int main()
{
    char PalavraOriginal[] = "computador";
    char PalavraVisivel[30];
    char LetraInformada;
    int TamanhoTexto;
    int Indice;
    int ErrosFeitos = 0;
    int LetrasAbertas = 0;
    int LetraEncontrada;

    TamanhoTexto = strlen(PalavraOriginal);

    // Prepara a palavra escondida com underline
    for (Indice = 0; Indice < TamanhoTexto; Indice++)
    {
        PalavraVisivel[Indice] = '_';
    }

    PalavraVisivel[TamanhoTexto] = '\0';

    printf("========================================\n");
    printf("           DESAFIO DA PALAVRA            \n");
    printf("========================================\n\n");

    printf("Tente descobrir a palavra secreta.\n");
    printf("Voce pode errar no maximo 6 vezes.\n\n");

    // Continua até o jogador vencer ou atingir o limite de erros
    while (ErrosFeitos < 6 && LetrasAbertas < TamanhoTexto)
    {
        printf("Palavra: ");

        for (Indice = 0; Indice < TamanhoTexto; Indice++)
        {
            printf("%c ", PalavraVisivel[Indice]);
        }

        printf("\nTentativas erradas: %d de 6\n", ErrosFeitos);
        printf("Informe uma letra: ");
        scanf(" %c", &LetraInformada);

        LetraEncontrada = 0;

        // Procura a letra digitada dentro da palavra original
        for (Indice = 0; Indice < TamanhoTexto; Indice++)
        {
            if (PalavraOriginal[Indice] == LetraInformada && PalavraVisivel[Indice] == '_')
            {
                PalavraVisivel[Indice] = LetraInformada;
                LetrasAbertas++;
                LetraEncontrada = 1;
            }
        }

        if (LetraEncontrada == 1)
        {
            printf("\nLetra aceita! Continue tentando.\n\n");
        }
        else
        {
            ErrosFeitos++;
            printf("\nLetra recusada! Ela nao aparece na palavra.\n\n");
        }
    }

    if (LetrasAbertas == TamanhoTexto)
    {
        printf("Vitoria! A palavra foi descoberta.\n");
        printf("Palavra final: %s\n", PalavraOriginal);
    }
    else
    {
        printf("Derrota! As tentativas acabaram.\n");
        printf("A palavra correta era: %s\n", PalavraOriginal);
    }

    return 0;
}